# Setup do .env
# Este arquivo é um TEMPLATE. Você NÃO deve commitar com dados sensíveis.
#
# 1. Copie este arquivo pra .env:
#    cp .env.example .env
#
# 2. Preencha as variáveis com seus valores locais (senhas, domínios, etc).
#    NÃO copie do git, é seu arquivo local e secreto.
#
# 3. Após mudar .env, às vezes precisa rodar (depende da mudança):
#    php artisan config:clear
#    cd docker && docker compose restart
#
# 4. Certifique-se que .env está NO .gitignore (já está por padrão no Laravel).
#
# VARIÁVEIS CRÍTICAS:
# - APP_KEY: gerado automaticamente por "docker compose up" (docker-compose.yml roda key:generate)
# - DB_PASSWORD, MYSQL_PASSWORD, MYSQL_ROOT_PASSWORD: credenciais do banco (valores diferentes em produção!)
# - SANCTUM_TOKEN_EXPIRATION: duração do token em minutos (120 = 2 horas)
# - API_RATE_LIMIT_READ/WRITE: limites de requisições por minuto (60/20 por padrão)
#
# Pesquise: "Laravel .env file", "environment variables", "12factor app"

APP_NAME="Viações Laravel Demo"
APP_ENV=local
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost:8082
APP_TIMEZONE=America/Sao_Paulo

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=viacoes_laravel_demo_db
DB_PORT=3306
DB_DATABASE=viacoes_demo
DB_USERNAME=viacoes_user
DB_PASSWORD=viacoes_pass
DB_TIMEZONE=-03:00
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

MYSQL_DATABASE=viacoes_demo
MYSQL_USER=viacoes_user
MYSQL_PASSWORD=viacoes_pass
MYSQL_ROOT_PASSWORD=root123
MYSQL_DEFAULT_TIMEZONE=-03:00

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

SANCTUM_STATEFUL_DOMAINS=localhost,localhost:8082,127.0.0.1,127.0.0.1:8082,::1
SANCTUM_TOKEN_EXPIRATION=120
SANCTUM_TOKEN_PREFIX=vdl_

API_RATE_LIMIT_READ=60
API_RATE_LIMIT_WRITE=20

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file

TELESCOPE_ENABLED=true

# E-mail
#
# AMBIENTE LOCAL (padrão neste arquivo):
# Usamos Mailhog, um servidor SMTP "fake" que captura todos os e-mails.
# Nenhum e-mail real é enviado, você visualiza tudo em http://localhost:8025
#
# O serviço Mailhog roda via Docker apenas localmente (docker/docker-compose.override.yml).
# Para republicar os templates de e-mail customizáveis (já fizemos nesse projeto):
#   php artisan vendor:publish --tag=laravel-notifications  → resources/views/vendor/notifications/
#   php artisan vendor:publish --tag=laravel-mail           → resources/views/vendor/mail/
#
# AMBIENTE DE PRODUÇÃO:
# Substituir pelos dados do provedor SMTP real (SES, Postmark, Mailgun, etc). NUNCA comite credenciais reais aqui.
# Pesquise: "Laravel Mail drivers".
#
MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="teste@viacoeslaravel.com"
MAIL_FROM_NAME="${APP_NAME}"
